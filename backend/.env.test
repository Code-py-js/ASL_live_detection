# Backend Test Environment Configuration
# Use this for testing: NODE_ENV=test npm test
# This disables rate limiting to allow comprehensive testing

MONGODB_URI=mongodb+srv://salah:Salah2004@cluster0.zmkufim.mongodb.net/asl_live_detection_test?retryWrites=true&w=majority
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB=asl_live_detection_test
MONGODB_USER=
MONGODB_PASS=

# Use in-memory database for fast testing
USE_IN_MEMORY_DB=true

JWT_SECRET=test_secret_key_with_sufficient_length
JWT_EXPIRY=7d
BCRYPT_ROUNDS=10

PORT=4000
LOG_LEVEL=warn

# CRITICAL: High thresholds for testing (no rate limiting)
# Production values: AUTH 5/15min, REGISTER 10/hour, API 100/min
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=10000

# CORS for local testing
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,http://127.0.0.1:3000,http://127.0.0.1:4000

# Node environment indicator
NODE_ENV=test
