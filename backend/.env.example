# Backend Configuration
# If your MongoDB requires authentication, set MONGODB_USER and MONGODB_PASS.
# Otherwise the plain host/port/database values below will be used.

MONGODB_URI=
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB=signconnect
MONGODB_USER=
MONGODB_PASS=

JWT_SECRET=replace_this_with_a_strong_secret
USE_IN_MEMORY_DB=true
PORT=4000
